<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#3A3D40">
  <title>{{ page_title }}</title>
  {%- if page_description -%}<meta name="description" content="{{ page_description | escape }}">{%- endif -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  {{ content_for_header }}
  <style>
    :root{
      --paper:#3A3D40;--paper-light:#44484C;--media:#F3F0E8;--ink:#ECE7DD;--ink-soft:#D3CDC3;
      --muted:#BEB8AE;--muted-soft:#ADA79D;--solid:#16110D;--on-dark:#F4EFE6;--ember:#E8571F;
      --ember-deep:#BB3D12;--amber:#EE9A33;--line:rgba(255,255,255,0.13);--line-strong:rgba(255,255,255,0.28);
    }
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Figtree',sans-serif;background:var(--paper);color:var(--ink);line-height:1.6;-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}
    .wrap{max-width:1160px;margin:0 auto;padding:0 24px}
    .site-head{position:sticky;top:0;z-index:10;background:rgba(22,17,13,0.92);backdrop-filter:blur(10px);border-bottom:1px solid var(--line)}
    .site-head .wrap{display:flex;align-items:center;justify-content:space-between;height:64px}
    .brand{font-weight:800;letter-spacing:-0.01em;font-size:1.15rem;color:var(--on-dark)}
    .brand em{color:var(--ember);font-style:normal}
    .site-nav a{margin-left:22px;color:var(--ink-soft);font-weight:500;font-size:0.95rem}
    .site-nav a:hover{color:var(--ember)}
    .site-foot{border-top:1px solid var(--line);margin-top:72px;padding:38px 0;color:var(--muted-soft);font-size:0.9rem}
    .site-foot .wrap{display:flex;justify-content:space-between;flex-wrap:wrap;gap:16px}
    .site-foot a:hover{color:var(--ember)}
    .btn{display:inline-flex;align-items:center;gap:8px;background:var(--ember);color:#fff;font-weight:700;padding:14px 26px;border-radius:10px;border:none;cursor:pointer;font-size:1rem;transition:background .2s}
    .btn:hover{background:var(--ember-deep)}
    .btn[disabled]{opacity:.5;cursor:not-allowed}
    .btn-ghost{background:transparent;border:1px solid var(--line-strong);color:var(--ink)}
    .btn-ghost:hover{border-color:var(--ember);color:var(--ember)}
    .crumb{padding:24px 0 0;color:var(--muted-soft);font-size:0.85rem}
    .crumb a:hover{color:var(--ember)}
    .pdp{padding:24px 0}
    .pdp-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start}
    .pdp-media{background:var(--media);border-radius:16px;padding:32px;display:flex;align-items:center;justify-content:center;min-height:420px}
    .pdp-media img,.pdp-media svg{border-radius:8px;object-fit:contain;max-height:460px;width:auto}
    .pdp-cat{text-transform:uppercase;letter-spacing:.12em;font-size:.72rem;color:var(--muted-soft);margin-bottom:8px}
    .pdp-info h1{font-size:2.1rem;font-weight:800;letter-spacing:-0.02em;line-height:1.15;color:var(--on-dark);margin-bottom:6px}
    .pdp-price{font-size:1.6rem;font-weight:800;color:var(--ember);margin:14px 0}
    .pdp-avail{font-size:.9rem;color:var(--ink-soft);margin-bottom:22px}
    .pdp-avail .dot{display:inline-block;width:8px;height:8px;border-radius:50%;background:#5fbf6a;margin-right:7px;vertical-align:middle}
    .pdp-avail.out .dot{background:#c2553f}
    .pdp-cta{display:flex;gap:12px;flex-wrap:wrap;margin:8px 0 4px}
    .pdp-desc{color:var(--ink-soft);margin:24px 0}
    .pdp-desc h3{color:var(--ink);font-size:1rem;margin:18px 0 8px}
    .pdp-desc ul{padding-left:20px;margin:8px 0}
    .pdp-desc p{margin:10px 0}
    .pdp-meta{margin-top:20px;font-size:.82rem;color:var(--muted-soft);border-top:1px solid var(--line);padding-top:16px}
    .coll-head{padding:40px 0 8px}
    .coll-head h1{font-size:2.3rem;font-weight:800;letter-spacing:-0.02em;color:var(--on-dark)}
    .coll-head p{color:var(--ink-soft);max-width:620px;margin-top:10px}
    .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:24px;padding:24px 0}
    .card{background:var(--paper-light);border:1px solid var(--line);border-radius:14px;overflow:hidden;transition:border-color .2s,transform .2s;display:block}
    .card:hover{border-color:var(--line-strong);transform:translateY(-2px)}
    .card-media{background:var(--media);aspect-ratio:1;display:flex;align-items:center;justify-content:center;padding:22px}
    .card-media img,.card-media svg{object-fit:contain;max-height:100%;width:auto}
    .card-body{padding:16px}
    .card-body h3{font-size:1rem;font-weight:600;color:var(--ink);margin-bottom:6px}
    .card-price{color:var(--ember);font-weight:700}
    .cart-row{display:flex;justify-content:space-between;gap:16px;padding:14px 0;border-bottom:1px solid var(--line);color:var(--ink-soft)}
    .cart-foot{display:flex;justify-content:space-between;align-items:center;padding-top:20px;flex-wrap:wrap;gap:16px}
    .cart-foot strong{font-size:1.2rem;color:var(--ink)}
    @media (max-width:760px){.pdp-grid{grid-template-columns:1fr;gap:24px}.pdp-media{min-height:300px}}
  </style>
</head>
<body>
  <header class="site-head">
    <div class="wrap">
      <a href="{{ routes.root_url }}" class="brand">Ember <em>&amp;</em> Iron</a>
      <nav class="site-nav">
        <a href="{{ routes.root_url }}">Home</a>
        <a href="{{ collections.grills.url }}">Grills</a>
        <a href="{{ collections.accessories.url }}">Accessories</a>
      </nav>
    </div>
  </header>
  <main>{{ content_for_layout }}</main>
  <footer class="site-foot">
    <div class="wrap">
      <span>&copy; {{ 'now' | date: '%Y' }} Ember &amp; Iron &mdash; Hand-built BBQ grills, Pakistan</span>
      <a href="{{ routes.root_url }}">Back to store &rarr;</a>
    </div>
  </footer>
</body>
</html>
