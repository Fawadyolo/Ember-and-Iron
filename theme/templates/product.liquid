{% layout 'product' %}
{%- assign v = product.selected_or_first_available_variant -%}
{%- assign first = product.images.first -%}
<div class="wrap">
  <nav class="crumb">
    <a href="{{ routes.root_url }}">Home</a> /
    {%- if product.type != blank %} <a href="{{ routes.collections_url }}/{{ product.type | handle }}">{{ product.type }}</a> /{% endif %}
    {{ product.title }}
  </nav>
  <article class="pdp">
    <div class="pdp-grid">

      <div class="pdp-media">
        {%- if product.images.size > 0 -%}
          <div class="pgal{% if product.images.size == 1 %} solo{% endif %}">
            {%- if product.images.size > 1 -%}
              <div class="pgal-thumbs" role="tablist" aria-label="Product photos">
                {%- for image in product.images -%}
                  <button type="button" class="pgal-thumb{% if forloop.first %} on{% endif %}"
                          role="tab" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                          data-full="{{ image | image_url: width: 1600 }}"
                          data-alt="{{ image.alt | default: product.title | escape }}"
                          aria-label="Show photo {{ forloop.index }}">
                    <img src="{{ image | image_url: width: 200 }}" alt="" width="88" height="88" loading="lazy" decoding="async">
                  </button>
                {%- endfor -%}
              </div>
            {%- endif -%}
            <div class="pgal-main" id="pgalMain">
              <img id="pgalMainImg"
                   src="{{ first | image_url: width: 1200 }}"
                   alt="{{ first.alt | default: product.title | escape }}"
                   width="1200" height="1200" loading="eager" decoding="async">
              <button type="button" class="pgal-zoom" aria-label="Zoom image">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3M11 8v6M8 11h6"/></svg>
              </button>
            </div>
          </div>
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag }}
        {%- endif -%}
      </div>

      <div class="pdp-info">
        {%- if product.type != blank -%}<div class="pdp-cat">{{ product.type }} &middot; Hand-built in Lahore</div>{%- endif -%}
        <h1>{{ product.title }}</h1>

        <div class="pdp-price-row">
          <span class="pdp-price">{{ v.price | money }}</span>
          {%- if v.compare_at_price > v.price -%}
            <s class="pdp-compare">{{ v.compare_at_price | money }}</s>
            <span class="pdp-save">Save {{ v.compare_at_price | minus: v.price | money }}</span>
          {%- endif -%}
        </div>

        {%- if product.available -%}
          <div class="pdp-avail"><span class="dot"></span>In stock &mdash; delivered across Pakistan</div>
        {%- else -%}
          <div class="pdp-avail out"><span class="dot"></span>Currently sold out</div>
        {%- endif -%}

        <ul class="pdp-points">
          <li><svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M20 6L9 17l-5-5"/></svg>Hand-welded carbon steel &mdash; built to outlive trends</li>
          <li><svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M20 6L9 17l-5-5"/></svg>Lifetime warranty against cookbox burn-through</li>
          <li><svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M20 6L9 17l-5-5"/></svg>Cash on delivery, nationwide</li>
        </ul>

        {%- form 'product', product, class: 'pdp-form' -%}
          <input type="hidden" name="id" value="{{ v.id }}">
          <div class="pdp-buy">
            <div class="qty" aria-label="Quantity">
              <button type="button" class="qty-btn" data-d="-1" aria-label="Decrease quantity">&minus;</button>
              <input type="number" name="quantity" id="pdpQty" value="1" min="1" inputmode="numeric" aria-label="Quantity">
              <button type="button" class="qty-btn" data-d="1" aria-label="Increase quantity">+</button>
            </div>
            <button type="submit" class="pdp-add"{% unless product.available %} disabled{% endunless %}>
              {% if product.available %}Add to cart{% else %}Sold out{% endif %}
            </button>
          </div>
        {%- endform -%}

        <div class="pdp-ship">
          <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M1 3h15v13H1zM16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <div>
            <strong>Free delivery</strong> on orders over PKR&nbsp;12,000
            <span>Ships nationwide &middot; Cash on delivery available</span>
          </div>
        </div>

        {%- if product.description != blank -%}
          <details class="pdp-detail" open>
            <summary>About this {{ product.type | default: 'product' | downcase }}</summary>
            <div class="pdp-desc">{{ product.description }}</div>
          </details>
        {%- endif -%}
        <details class="pdp-detail">
          <summary>Delivery &amp; returns</summary>
          <div class="pdp-desc">
            <p>Standard delivery is PKR 350; orders over PKR 12,000 ship free anywhere in Pakistan. Cash on delivery is available nationwide.</p>
            <p>Items that arrive damaged, or an incorrect order, are replaced or refunded &mdash; report within 48 hours at returns@emberandiron.pk. All other sales are final.</p>
          </div>
        </details>

        <div class="pdp-meta">SKU: {{ v.sku | default: product.handle }}</div>
      </div>
    </div>
  </article>
</div>

<div class="pgal-lightbox" id="pgalZoom" aria-hidden="true">
  <button type="button" class="pgal-lb-close" aria-label="Close">&times;</button>
  <img id="pgalZoomImg" src="" alt="" width="1600" height="1600">
  <div class="pgal-lb-hint">Click image to magnify &middot; Esc to close</div>
</div>

<style>
  /* ── whiskit-pattern gallery: vertical thumb rail + sticky main stage ── */
  .pdp-grid { display: grid; grid-template-columns: minmax(0, 1.08fr) minmax(0, .92fr); gap: 56px; align-items: start; }
  .pdp-media { position: sticky; top: 88px; }
  .pgal { display: grid; grid-template-columns: 88px minmax(0, 1fr); gap: 14px; align-items: start; }
  .pgal.solo { grid-template-columns: minmax(0, 1fr); }
  .pgal-main { position: relative; width: 100%; aspect-ratio: 1 / 1; background: var(--media); border: 1px solid var(--line); border-radius: 18px; overflow: hidden; cursor: zoom-in; }
  .pgal-main > img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .pgal-zoom { position: absolute; top: 14px; right: 14px; width: 42px; height: 42px; display: grid; place-items: center; border: 0; border-radius: 50%; background: rgba(13,9,6,.55); color: #fff; cursor: pointer; z-index: 2; -webkit-backdrop-filter: blur(4px); backdrop-filter: blur(4px); transition: background .2s ease; }
  .pgal-zoom:hover { background: var(--ember-deep); }
  .pgal-thumbs { display: flex; flex-direction: column; gap: 10px; max-height: min(44vw, 640px); overflow-y: auto; scrollbar-width: none; -ms-overflow-style: none; }
  .pgal-thumbs::-webkit-scrollbar { display: none; }
  .pgal-thumb { flex: 0 0 auto; width: 88px; height: 88px; padding: 0; border: 2px solid transparent; border-radius: 12px; overflow: hidden; background: var(--media); cursor: pointer; transition: border-color .2s ease, opacity .2s ease; opacity: .82; }
  .pgal-thumb > img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pgal-thumb.on { border-color: var(--ember); opacity: 1; }
  .pgal-thumb:hover { border-color: var(--line-strong); opacity: 1; }

  /* ── info column (whiskit hierarchy: title → price → proof → buy) ── */
  .pdp-info h1 { font-family: 'Anton', 'Figtree', sans-serif; font-weight: 400; text-transform: uppercase; letter-spacing: .015em; font-size: clamp(1.9rem, 3.4vw, 2.9rem); line-height: 1.04; color: var(--on-dark); margin: 6px 0 14px; }
  .pdp-cat { text-transform: uppercase; letter-spacing: .16em; font-size: .72rem; color: var(--ember); font-weight: 700; }
  .pdp-price-row { display: flex; align-items: baseline; gap: 14px; flex-wrap: wrap; margin: 4px 0 10px; }
  .pdp-price { font-size: 1.9rem; font-weight: 800; color: var(--on-dark); }
  .pdp-compare { color: var(--muted-soft); font-size: 1.15rem; }
  .pdp-save { background: var(--ember); color: #fff; font-size: .78rem; font-weight: 800; letter-spacing: .04em; padding: 5px 12px; border-radius: 999px; }
  .pdp-avail { font-size: .9rem; color: var(--ink-soft); margin-bottom: 20px; }
  .pdp-points { list-style: none; padding: 0; margin: 0 0 26px; display: grid; gap: 10px; }
  .pdp-points li { display: flex; gap: 10px; align-items: baseline; color: var(--ink-soft); font-size: .97rem; }
  .pdp-points svg { color: var(--ember); flex: 0 0 auto; transform: translateY(2px); }

  /* ── buy row: stepper + one loud CTA (whiskit) ── */
  .pdp-buy { display: flex; gap: 12px; align-items: stretch; margin: 0 0 18px; }
  .qty { display: flex; align-items: center; border: 1px solid var(--line-strong); border-radius: 12px; overflow: hidden; background: var(--paper-light); }
  .qty-btn { width: 46px; height: 52px; border: 0; background: transparent; color: var(--ink); font-size: 1.25rem; cursor: pointer; transition: background .15s ease; }
  .qty-btn:hover { background: rgba(242,235,222,.08); }
  .qty input { width: 48px; height: 52px; border: 0; background: transparent; color: var(--ink); font-size: 1.05rem; font-weight: 700; text-align: center; -moz-appearance: textfield; }
  .qty input::-webkit-outer-spin-button, .qty input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  .pdp-add { flex: 1; height: 52px; border: 0; border-radius: 12px; background: var(--ember); color: #fff; font-family: 'Figtree', sans-serif; font-size: 1rem; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; cursor: pointer; transition: background .2s ease, transform .2s ease, box-shadow .2s ease; }
  .pdp-add:hover { background: var(--ember-deep); transform: translateY(-1px); box-shadow: 0 10px 28px rgba(232,87,31,.32); }
  .pdp-add[disabled] { opacity: .45; cursor: not-allowed; transform: none; box-shadow: none; }

  /* ── trust card + accordions ── */
  .pdp-ship { display: flex; gap: 14px; align-items: center; background: var(--paper-light); border: 1px solid var(--line); border-radius: 14px; padding: 16px 18px; margin-bottom: 26px; }
  .pdp-ship svg { color: var(--ember); flex: 0 0 auto; }
  .pdp-ship strong { color: var(--ink); }
  .pdp-ship span { display: block; font-size: .84rem; color: var(--muted); margin-top: 2px; }
  .pdp-detail { border-top: 1px solid var(--line); }
  .pdp-detail summary { list-style: none; cursor: pointer; padding: 16px 0; font-weight: 700; color: var(--ink); display: flex; justify-content: space-between; align-items: center; }
  .pdp-detail summary::-webkit-details-marker { display: none; }
  .pdp-detail summary::after { content: '+'; color: var(--ember); font-size: 1.2rem; font-weight: 400; transition: transform .2s ease; }
  .pdp-detail[open] summary::after { transform: rotate(45deg); }
  .pdp-detail .pdp-desc { margin: 0 0 18px; }
  .pdp-meta { border-top: 1px solid var(--line); }

  @media (max-width: 900px) {
    .pdp-grid { grid-template-columns: 1fr; gap: 30px; }
    .pdp-media { position: static; }
    .pgal { grid-template-columns: 1fr; }
    .pgal-thumbs { flex-direction: row; max-height: none; overflow-x: auto; overflow-y: hidden; order: 2; }
    .pgal-thumb { width: 64px; height: 64px; }
    .pgal-main { order: 1; }
  }

  /* ── zoom lightbox ── */
  .pgal-lightbox { position: fixed; inset: 0; z-index: 99999; background: rgba(13,9,6,.95); display: none; align-items: center; justify-content: center; }
  .pgal-lightbox.open { display: flex; }
  .pgal-lightbox > img { max-width: 92vw; max-height: 92vh; width: auto; height: auto; object-fit: contain; cursor: zoom-in; transition: transform .2s ease; will-change: transform; }
  .pgal-lightbox > img.zoomed { transform: scale(2.4); cursor: zoom-out; }
  .pgal-lb-close { position: fixed; top: 16px; right: 20px; width: 46px; height: 46px; border: 0; border-radius: 50%; background: rgba(255,255,255,.14); color: #fff; font-size: 28px; line-height: 1; cursor: pointer; z-index: 100000; }
  .pgal-lb-close:hover { background: rgba(255,255,255,.28); }
  .pgal-lb-hint { position: fixed; bottom: 18px; left: 0; right: 0; text-align: center; color: rgba(255,255,255,.6); font-size: 13px; letter-spacing: .03em; pointer-events: none; }
</style>
<script>
(function () {
  function mainImg() { return document.getElementById('pgalMainImg'); }
  function overlay() { return document.getElementById('pgalZoom'); }
  function zoomImg() { return document.getElementById('pgalZoomImg'); }

  function selectThumb(btn) {
    var full = btn.getAttribute('data-full');
    var alt = btn.getAttribute('data-alt') || '';
    var mi = mainImg();
    if (mi && full) { mi.src = full; mi.alt = alt; }
    var all = document.querySelectorAll('.pgal-thumb');
    for (var i = 0; i < all.length; i++) {
      var on = all[i] === btn;
      all[i].classList.toggle('on', on);
      all[i].setAttribute('aria-selected', on ? 'true' : 'false');
    }
    if (btn.scrollIntoView) btn.scrollIntoView({ block: 'nearest', inline: 'center', behavior: 'smooth' });
  }
  function openZoom() {
    var mi = mainImg(); if (!mi) return;
    var zi = zoomImg();
    zi.src = mi.currentSrc || mi.src; zi.alt = mi.alt;
    zi.classList.remove('zoomed'); zi.style.transformOrigin = 'center center';
    overlay().classList.add('open'); overlay().setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeZoom() {
    var ov = overlay(); if (!ov) return;
    ov.classList.remove('open'); ov.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  document.addEventListener('click', function (e) {
    var thumb = e.target.closest && e.target.closest('.pgal-thumb');
    if (thumb) { selectThumb(thumb); return; }
    var qbtn = e.target.closest && e.target.closest('.qty-btn');
    if (qbtn) {
      var q = document.getElementById('pdpQty');
      q.value = Math.max(1, (parseInt(q.value, 10) || 1) + parseInt(qbtn.dataset.d, 10));
      return;
    }
    if (e.target.closest && (e.target.closest('.pgal-zoom') || e.target.closest('.pgal-main'))) { openZoom(); return; }
    if (e.target.closest && e.target.closest('.pgal-lb-close')) { closeZoom(); return; }
    if (e.target === overlay()) closeZoom();
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') { closeZoom(); return; }
    if ((e.key === 'ArrowLeft' || e.key === 'ArrowRight' || e.key === 'ArrowUp' || e.key === 'ArrowDown') && document.querySelector('.pgal-thumb')) {
      if (/^(INPUT|TEXTAREA)$/.test(document.activeElement.tagName)) return;
      var list = Array.prototype.slice.call(document.querySelectorAll('.pgal-thumb'));
      var idx = 0;
      for (var i = 0; i < list.length; i++) if (list[i].classList.contains('on')) idx = i;
      var fwd = (e.key === 'ArrowRight' || e.key === 'ArrowDown') ? 1 : -1;
      selectThumb(list[(idx + fwd + list.length) % list.length]);
    }
  });
  document.addEventListener('DOMContentLoaded', function () {
    var zi = zoomImg(); if (!zi) return;
    zi.addEventListener('click', function (e) { e.stopPropagation(); this.classList.toggle('zoomed'); });
    zi.addEventListener('mousemove', function (e) {
      if (!this.classList.contains('zoomed')) return;
      var r = this.getBoundingClientRect();
      this.style.transformOrigin = ((e.clientX - r.left) / r.width * 100) + '% ' + ((e.clientY - r.top) / r.height * 100) + '%';
    });
    zi.addEventListener('touchmove', function (e) {
      if (!this.classList.contains('zoomed') || !e.touches[0]) return;
      var r = this.getBoundingClientRect();
      this.style.transformOrigin = ((e.touches[0].clientX - r.left) / r.width * 100) + '% ' + ((e.touches[0].clientY - r.top) / r.height * 100) + '%';
    }, { passive: true });
  });
})();
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 300 | json }},
  {%- if product.images.size > 0 -%}
  "image": [{% for image in product.images %}{{ image | image_url: width: 1200 | prepend: "https:" | json }}{% unless forloop.last %},{% endunless %}{% endfor %}],
  {%- endif -%}
  "sku": {{ v.sku | json }},
  "brand": { "@type": "Brand", "name": "Ember & Iron" },
  "offers": {
    "@type": "Offer",
    "price": {{ v.price | divided_by: 100.0 | json }},
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition",
    "url": {{ product.url | prepend: request.origin | json }}
  }
}
</script>
