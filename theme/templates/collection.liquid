{% layout 'product' %}
<div class="wrap">
  <nav class="crumb"><a href="{{ routes.root_url }}">Home</a> / {{ collection.title }}</nav>
  <header class="coll-head">
    <h1>{{ collection.title }}</h1>
    {%- if collection.description != blank -%}<p>{{ collection.description | strip_html }}</p>{%- endif -%}
  </header>
  {%- paginate collection.products by 24 -%}
  <div class="grid">
    {%- for product in collection.products -%}
      <a class="card" href="{{ product.url }}">
        <div class="card-media">
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title | escape }}" width="500" height="500" loading="lazy" decoding="async">
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag }}
          {%- endif -%}
        </div>
        <div class="card-body">
          <h3>{{ product.title }}</h3>
          <div class="card-price">{{ product.price | money }}</div>
        </div>
      </a>
    {%- else -%}
      <p>No products in this collection yet.</p>
    {%- endfor -%}
  </div>
  {%- if paginate.pages > 1 -%}
    <div class="crumb">{{ paginate | default_pagination }}</div>
  {%- endif -%}
  {%- endpaginate -%}
</div>
