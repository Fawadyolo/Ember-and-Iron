{% layout 'product' %}
<div class="wrap">
  <nav class="crumb"><a href="{{ routes.root_url }}">Home</a> / {{ blog.title }}</nav>
  <header class="coll-head">
    <h1>{{ blog.title }}</h1>
    <p>Fire craft, grilling guides and workshop notes from Ember &amp; Iron.</p>
  </header>
  {%- paginate blog.articles by 12 -%}
  <div class="grid">
    {%- for article in blog.articles -%}
      <a class="card" href="{{ article.url }}">
        {%- if article.image -%}
          <div class="card-media">
            <img src="{{ article.image | image_url: width: 500 }}" alt="{{ article.title | escape }}" width="500" height="500" loading="lazy" decoding="async">
          </div>
        {%- endif -%}
        <div class="card-body">
          <h3>{{ article.title }}</h3>
          <div class="pdp-cat">{{ article.published_at | date: '%-d %B %Y' }}</div>
          {%- if article.excerpt != blank -%}<p style="color:var(--ink-soft);font-size:.9rem;margin-top:8px">{{ article.excerpt | strip_html | truncate: 120 }}</p>{%- endif -%}
        </div>
      </a>
    {%- else -%}
      <p style="color:var(--ink-soft);padding:24px 0">No posts yet — the first fire-craft guides are being written. <a href="{{ routes.root_url }}" style="color:var(--ember)">Back to the store &rarr;</a></p>
    {%- endfor -%}
  </div>
  {%- if paginate.pages > 1 -%}
    <div class="crumb">{{ paginate | default_pagination }}</div>
  {%- endif -%}
  {%- endpaginate -%}
</div>
