{% layout 'product' %}
<div class="wrap">
  <nav class="crumb"><a href="{{ routes.root_url }}">Home</a> / Search</nav>
  <header class="coll-head">
    <h1>{% if search.performed %}Results for &ldquo;{{ search.terms | escape }}&rdquo;{% else %}Search{% endif %}</h1>
    {%- if search.performed -%}<p>{{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %}</p>{%- endif -%}
  </header>
  <form action="{{ routes.search_url }}" method="get" role="search" style="display:flex;gap:12px;max-width:520px;margin:8px 0 16px">
    <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search grills, charcoal, tools…" aria-label="Search the store"
      style="flex:1;background:var(--paper-light);border:1px solid var(--line-strong);border-radius:10px;padding:13px 16px;color:var(--ink);font-family:inherit;font-size:1rem">
    <button class="btn" type="submit">Search</button>
  </form>
  {%- if search.performed -%}
    {%- paginate search.results by 24 -%}
    <div class="grid">
      {%- for item in search.results -%}
        <a class="card" href="{{ item.url }}">
          <div class="card-media">
            {%- if item.featured_image -%}
              <img src="{{ item.featured_image | image_url: width: 500 }}" alt="{{ item.title | escape }}" width="500" height="500" loading="lazy" decoding="async">
            {%- elsif item.image -%}
              <img src="{{ item.image | image_url: width: 500 }}" alt="{{ item.title | escape }}" width="500" height="500" loading="lazy" decoding="async">
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          <div class="card-body">
            <h3>{{ item.title }}</h3>
            {%- if item.price -%}<div class="card-price">{{ item.price | money }}</div>{%- endif -%}
          </div>
        </a>
      {%- else -%}
        <p style="color:var(--ink-soft);padding:24px 0">Nothing matched &ldquo;{{ search.terms | escape }}&rdquo;. Try &ldquo;grill&rdquo;, &ldquo;charcoal&rdquo; or &ldquo;thermometer&rdquo;.</p>
      {%- endfor -%}
    </div>
    {%- if paginate.pages > 1 -%}
      <div class="crumb">{{ paginate | default_pagination }}</div>
    {%- endif -%}
    {%- endpaginate -%}
  {%- endif -%}
</div>
