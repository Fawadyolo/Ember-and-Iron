{% layout 'product' %}
<div class="wrap" style="text-align:center;padding:80px 24px">
  <div class="pdp-cat">404 — Not found</div>
  <h1 style="font-size:2.3rem;font-weight:800;color:var(--on-dark);margin:12px 0">This page went cold.</h1>
  <p style="color:var(--ink-soft);max-width:480px;margin:0 auto 28px">The link you followed doesn't exist any more — but the fire's still going on the main store.</p>
